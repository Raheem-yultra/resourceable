generator client {
  provider = "prisma-client-js"
  // relationJoins lets read queries fetch relations with a single DB round-trip
  // (LATERAL join) instead of one query per relation. Big win on remote/pooled
  // connections (Supabase) where each extra round-trip costs real latency.
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String          @id @default(cuid())
  email                     String          @unique
  name                      String?
  password                  String
  role                      UserRole        @default(USER)
  emailVerified             DateTime?
  emailVerificationToken    String?         @unique
  emailVerificationExpiry   DateTime?
  image                     String?
  phone                     String?
  isActive                  Boolean         @default(true)
  lastLoginAt               DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  resetToken                String?         @unique
  resetTokenExpiry          DateTime?
  business                  Business?
  favorites                 Favorite[]
  receivedMessages          Message[]       @relation("ReceivedMessages")
  sentMessages              Message[]       @relation("SentMessages")
  reviews                   Review[]
  searchHistory             SearchHistory[]
  adminActions              AdminAction[]   @relation("AdminActions")
  reports                   Report[]        @relation("UserReports")

  @@index([email])
  @@index([role])
  @@index([resetToken])
  @@index([emailVerificationToken])
}

model Business {
  id                   String               @id @default(cuid())
  userId               String               @unique
  businessName         String
  businessType         String?
  description          String?
  phone                String?
  email                String?
  website              String?
  address              String?
  addressLine2         String?
  city                 String?
  state                String?
  zipCode              String?
  country              String               @default("USA")
  latitude             Float?
  longitude            Float?
  logo                 String?
  coverImage           String?
  yearEstablished      Int?
  licenseNumber        String?
  taxId                String?
  // National Provider Identifier. Structured (unlike the free-text licenseNumber)
  // precisely so it can be matched against the public NPPES registry — see
  // lib/verification. Any provider who bills insurance has one.
  npi                  String?
  // Last time the automated pre-approval checks ran (lib/verification).
  checksRunAt          DateTime?
  verificationStatus   VerificationStatus   @default(PENDING)
  // Trust tier for the third-party marketplace (plan §4). Distinct from
  // verificationStatus (the approval gate): a business can be APPROVED yet only
  // UNVERIFIED until an admin confirms credentials. Listings inherit this tier
  // (denormalized onto Service.verificationLevel for fast search filtering).
  verificationLevel    VerificationLevel    @default(UNVERIFIED)
  verifiedAt           DateTime?
  verifiedBy           String?
  rejectionReason      String?
  adminNotes           String?
  reviewedBy           String?
  reviewedAt           DateTime?
  // Suspension is tracked separately from verificationStatus so approval history is preserved.
  // Public visibility already keys off isActive, so suspending sets isActive = false.
  isSuspended          Boolean              @default(false)
  suspendedAt          DateTime?
  suspendedBy          String?
  suspensionReason     String?
  isActive             Boolean              @default(true)
  isFeatured           Boolean              @default(false)
  hoursOfOperation     Json?
  viewCount            Int                  @default(0)
  contactCount         Int                  @default(0)
  averageRating        Float?
  totalReviews         Int                  @default(0)
  // --- Stripe billing. Only businesses (providers) are billed; families never are. ---
  // Kept on Business rather than a separate BillingAccount to match the existing pattern
  // of colocating lifecycle/status flags here, and to keep access-gating filters flat
  // (search already filters on Business fields — a 1:1 relation would force nested
  // null-handling everywhere). subscriptionStatus is null until billing starts at approval.
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   SubscriptionStatus?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  // Set the first time this account is granted a free trial. Once set, any
  // re-subscribe (e.g. after canceling) skips the trial — one trial per account.
  trialUsedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessDisabilities BusinessDisability[]
  favorites            Favorite[]
  reviews              Review[]
  services             Service[]
  verificationChecks   VerificationCheck[]

  @@index([userId])
  @@index([zipCode])
  @@index([city, state])
  @@index([verificationStatus])
  @@index([verificationLevel])
  @@index([subscriptionStatus])
  @@index([isActive, verificationStatus])
  @@index([isFeatured])
}

model Service {
  id                  String              @id @default(cuid())
  businessId          String
  name                String
  slug                String
  description         String
  shortDescription    String?             @default("") @db.VarChar(200)
  priceRange          PriceRange          @default(CONTACT)
  priceMin            Decimal?            @db.Decimal(10, 2)
  priceMax            Decimal?            @db.Decimal(10, 2)
  pricingDetails      String?
  ageGroups           AgeGroup[]
  ageMin              Int?
  ageMax              Int?
  capacity            Int?
  currentAvailability Int?
  duration            String?
  frequency           String?
  insuranceAccepted   Boolean             @default(false)
  insuranceProviders  String[]            @default([])
  languages           String[]            @default(["English"])
  isActive            Boolean             @default(true)
  isAvailable         Boolean             @default(true)
  startDate           DateTime?
  endDate             DateTime?
  metaTitle           String?
  metaDescription     String?
  // --- Category-expansion (plan §3): the single generic Service becomes one of
  // several bookable listing kinds. Existing rows default to SERVICE so nothing
  // pre-billing/pre-expansion breaks. Resources are NOT listings (see Resource). ---
  listingType         ListingType         @default(SERVICE)
  // Trust tier denormalized from the owning Business for fast search filter/sort.
  // Kept in sync when the business tier changes (see lib/verification helpers).
  verificationLevel   VerificationLevel   @default(UNVERIFIED)
  deliveryMode        DeliveryMode?       // in-person / virtual / both (Services, Therapies, Events)
  // Shop extension fields
  condition           ItemCondition?      // new / used-like-new / used-fair
  isForRent           Boolean             @default(false)
  brand               String?
  images              String[]            @default([])
  // School extension fields
  enrollmentStatus    String?             // e.g. "Open", "Waitlist", "Closed"
  gradeLevels         String[]            @default([])
  programType         String?
  // Event extension fields (startDate/endDate/capacity above are reused)
  isVirtual           Boolean             @default(false)
  rsvpCount           Int                 @default(0)
  // Per-listing review aggregates (multi-listing marketplace): each listing is
  // reviewed independently, so ratings live here, not only on Business. Recomputed
  // whenever a review is created/updated (see app/api/reviews).
  averageRating       Float?
  totalReviews        Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  business            Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceDisabilities ServiceDisability[]
  serviceTypes        ServiceTypeMap[]
  reports             Report[]
  reviews             Review[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([isActive, isAvailable])
  @@index([priceRange])
  @@index([listingType])
  @@index([listingType, isActive])
  @@index([verificationLevel])
}

model Disability {
  id                   String               @id @default(cuid())
  name                 String               @unique
  slug                 String               @unique
  description          String?
  category             String?
  commonSymptoms       String[]             @default([])
  relatedConditions    String[]             @default([])
  prevalence           String?
  isActive             Boolean              @default(true)
  displayOrder         Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  businessDisabilities BusinessDisability[]
  serviceDisabilities  ServiceDisability[]

  @@index([slug])
  @@index([category])
  @@index([isActive, displayOrder])
}

model BusinessDisability {
  id           String     @id @default(cuid())
  businessId   String
  disabilityId String
  isPrimary    Boolean    @default(false)
  experience   Int?
  createdAt    DateTime   @default(now())
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  disability   Disability @relation(fields: [disabilityId], references: [id], onDelete: Cascade)

  @@unique([businessId, disabilityId])
  @@index([businessId])
  @@index([disabilityId])
  @@index([isPrimary])
}

model ServiceDisability {
  id           String     @id @default(cuid())
  serviceId    String
  disabilityId String
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  disability   Disability @relation(fields: [disabilityId], references: [id], onDelete: Cascade)
  service      Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, disabilityId])
  @@index([serviceId])
  @@index([disabilityId])
}

model ServiceType {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  description  String?
  category     String?
  // Which top-level marketplace category this subcategory belongs to (plan §2.2).
  // Nullable: legacy service types created before the expansion stay untyped and
  // still work as generic filters. New seeded subcategories set this.
  listingType  ListingType?
  icon         String?
  isActive     Boolean          @default(true)
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  services     ServiceTypeMap[]

  @@index([slug])
  @@index([category])
  @@index([listingType])
  @@index([isActive, displayOrder])
}

model ServiceTypeMap {
  id            String      @id @default(cuid())
  serviceId     String
  serviceTypeId String
  isPrimary     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@unique([serviceId, serviceTypeId])
  @@index([serviceId])
  @@index([serviceTypeId])
}

model Message {
  id          String        @id @default(cuid())
  senderId    String
  receiverId  String
  subject     String?
  content     String
  status      MessageStatus @default(SENT)
  readAt      DateTime?
  repliedAt   DateTime?
  parentId    String?
  attachments String[]      @default([])
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  receiver    User          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender      User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
  @@index([senderId, receiverId])
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  businessId   String
  // Reviews are per-listing (multi-listing marketplace). serviceId is nullable only
  // to preserve any legacy business-level reviews; new reviews always set it, and
  // uniqueness is enforced per (user, listing) so a user reviews each listing once.
  serviceId    String?
  rating       Int
  title        String?
  content      String
  pros         String[] @default([])
  cons         String[] @default([])
  isVerified   Boolean  @default(false)
  isPublished  Boolean  @default(true)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([businessId])
  @@index([serviceId])
  @@index([rating])
  @@index([isPublished])
  @@index([createdAt])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  notes      String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model SearchHistory {
  id            String   @id @default(cuid())
  userId        String?
  query         String?
  zipCode       String?
  city          String?
  state         String?
  disabilityId  String?
  serviceTypeId String?
  filters       Json?
  resultsCount  Int?
  clickedResult String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([zipCode])
  @@index([createdAt])
}

// Immutable audit log of admin actions — one row per action, never overwritten,
// so the full history of who did what (and why) to a record is preserved.
model AdminAction {
  id          String          @id @default(cuid())
  adminId     String
  admin       User            @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  action      AdminActionType
  targetType  String // "Business" | "ServiceType" | "Disability"
  targetId    String
  targetLabel String? // human-readable snapshot (e.g. business name) in case the target is later deleted
  reason      String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

enum AdminActionType {
  BUSINESS_APPROVED
  BUSINESS_REJECTED
  BUSINESS_SUSPENDED
  BUSINESS_UNSUSPENDED
  BUSINESS_REMOVED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_ARCHIVED
  CATEGORY_RESTORED
  BUSINESS_BILLING_OVERRIDE
  BUSINESS_VERIFICATION_LEVEL
  BUSINESS_CHECKS_RUN
  REPORT_RESOLVED
  RESOURCE_CREATED
  RESOURCE_UPDATED
  RESOURCE_ARCHIVED
}

// One row per automated pre-approval check per business (lib/verification). These are
// evidence for the admin, never an automatic decision — approval stays manual.
// Upserted on ([businessId, type]) so each business holds the CURRENT result of each
// check; the history of who acted on them lives in AdminAction.
model VerificationCheck {
  id         String                  @id @default(cuid())
  businessId String
  type       VerificationCheckType
  result     VerificationCheckResult
  // One-line human-readable verdict rendered directly in the admin queue.
  summary    String
  // Raw evidence (matched NPPES record, geocoder response, duplicate ids, ...) so an
  // admin can audit WHY a check passed without re-querying the external source.
  details    Json?
  checkedAt  DateTime                @default(now())
  business   Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId])
  @@index([result])
}

enum VerificationCheckType {
  EMAIL_DOMAIN // account email vs. the business's own domain
  WEBSITE // domain resolves, site is live, registration age
  PHONE // NANP format/plausibility (see note in lib/verification/checks.ts)
  ADDRESS // resolves against the US Census geocoder; not a PO box
  DUPLICATE // collides with an existing business (phone/domain/address/NPI)
  NPI // matches an active NPPES registry record
}

enum VerificationCheckResult {
  PASS
  WARN // suspicious but not disqualifying — admin should look
  FAIL // contradicted by an authoritative source
  SKIPPED // provider supplied nothing to check
  ERROR // external source unavailable; says nothing about the provider
}

// Records every Stripe webhook event id we've fully processed, so retried/duplicate
// deliveries are ignored (idempotency). Written after successful handling.
model ProcessedStripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

// User-submitted report/flag on a listing (plan §4). Available on every listing
// from launch given the vulnerable population served. Nullable reporter so an
// anonymous/guest report is possible and survives the reporter being deleted.
model Report {
  id           String       @id @default(cuid())
  serviceId    String?
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  businessId   String?
  reportedById String?
  reportedBy   User?        @relation("UserReports", fields: [reportedById], references: [id], onDelete: SetNull)
  reason       String
  details      String?
  status       ReportStatus @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
}

// Informational content (plan §2.1 type B): no provider, price, or location.
// Deliberately NOT part of the Listing/Service search index — it's a knowledge
// base searched by topic tag, not a location-based marketplace search.
model Resource {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  summary      String?
  body         String
  topicTags    String[]     @default([])
  resourceType ResourceType @default(ARTICLE)
  externalUrl  String?
  isPublished  Boolean      @default(true)
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([slug])
  @@index([resourceType])
  @@index([isPublished, displayOrder])
}

enum UserRole {
  USER
  BUSINESS
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Values are lowercase to mirror Stripe's subscription.status wire format, so webhook
// sync is a near-direct assignment. `suspended_billing` is app-specific: it's the state
// after Stripe's dunning/retry schedule is exhausted (Stripe reports unpaid/canceled).
enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  suspended_billing
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum AgeGroup {
  INFANT
  TODDLER
  CHILD
  TEEN
  ADULT
  ALL_AGES
}

enum PriceRange {
  FREE
  LOW
  MEDIUM
  HIGH
  PREMIUM
  CONTACT
}

// --- Category-expansion enums (plan §2.2 / §3) ---

// Top-level bookable listing kind. Resources are informational (separate model),
// so they are intentionally NOT a member here.
enum ListingType {
  SERVICE
  THERAPY
  SHOP
  SCHOOL
  EVENT
}

// Tiered provider trust (plan §4), not a binary verified flag.
enum VerificationLevel {
  UNVERIFIED
  BASIC_VERIFIED
  LICENSED
}

enum DeliveryMode {
  IN_PERSON
  VIRTUAL
  BOTH
}

enum ItemCondition {
  NEW
  USED_LIKE_NEW
  USED_FAIR
}

enum ResourceType {
  ARTICLE
  GUIDE
  HOTLINE
  FORM
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}
